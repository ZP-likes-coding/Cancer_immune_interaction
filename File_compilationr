# Append the immune infiltration info to the in vivo dataset
# 2) Transpose immune infiltration -> sample x immune_feature
immune_t <- as.data.frame(t(immune_inf))

# (Optional) make sure column names are syntactically safe in R
colnames(immune_t) <- make.names(colnames(immune_t), unique = TRUE)

# 3) Find shared sample IDs between Seurat and immune table
common <- intersect(colnames(seurat_vivo), rownames(immune_t))
length(common)          # how many samples can be annotated?
head(common)

# 4) Subset to shared samples (and keep ordering aligned)
# If you want to keep ALL samples in Seurat but only add metadata for those available:
immune_t_common <- immune_t[common, , drop = FALSE]
seurat_vivo <- AddMetaData(seurat_vivo, metadata = immune_t_common)

# 5) Quick check: did columns get added?
# Pick one immune feature you know exists, e.g. "Neutrophil_xCell" (after make.names, becomes Neutrophil_xCell)
head(seurat_vivo@meta.data[, c("nCount_RNA", "nFeature_RNA", "Neutrophil_xCell")])

saveRDS(seurat_vivo, file = "TISMO_vivo_compiled.rds")


# save the in vitro object as well
saveRDS(seurat_vitro, file = "TISMO_vitro_compiled.rds")
