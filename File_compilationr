)

# In-vivo datasets
seurat_vivo <- CreateSeuratObject(
  counts = expr_vivo,
  project = "TISMO_vivo"
)

# Attach metadata(In vitro and in vivo respectively)
meta_vitro <- as.data.frame(meta_vitro)
rownames(meta_vitro) <- meta_vitro$sample

seurat_vitro <- AddMetaData(
  seurat_vitro,
  metadata = meta_vitro
)

meta_vivo <- as.data.frame(meta_vivo)
rownames(meta_vivo) <- meta_vivo$sample

seurat_vivo <- AddMetaData(
  seurat_vivo,
